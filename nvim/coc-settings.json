{
    "languageserver": {
      "golang": {
        "command": "gopls",
        "rootPatterns": ["go.mod"],
        "filetypes": ["go"]
      }
    },
    "coc.preferences.formatOnSaveFiletypes": [
      "javascript",
      "javascriptreact",
      "typescript",
      "typescriptreact"
    ],
    "tsserver.formatOnType": true,
    "coc.preferences.formatOnType": true,
    "eslint.autoFixOnSave": true,
    "prettier.disableSuccessMessage": true
}




